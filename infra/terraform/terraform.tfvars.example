# Copy this to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

aws_region  = "eu-west-1"
project     = "phoenix"
environment = "prod"

# Ubuntu 22.04 LTS (eu-west-1). Find AMI for your region:
# aws ec2 describe-images --owners 099720109477 \
#   --filters 'Name=name,Values=ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*' \
#   --query 'sort_by(Images,&CreationDate)[-1].ImageId'
ami_id = "ami-0694d931cee176e7d"

# Paste the CONTENTS of your public key (e.g. ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA... you@machine"

# Your home/office IP — only this IP can SSH to the nodes
allowed_ssh_cidr = "1.2.3.4/32"

# S3 bucket you created for state (must exist before terraform init)
s3_state_bucket = "your-phoenix-tfstate-bucket"

# Instance sizes — t3.small is ~$15/mo each, fine for this capstone
control_plane_instance_type = "t3.small"
worker_instance_type        = "t3.small"
worker_count                = 2
